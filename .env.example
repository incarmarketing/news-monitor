# Naver News API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Google Gemini API
GEMINI_API_KEY=

# Optional AI fallback for issue-only summaries
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_ISSUE_SUMMARIES=20

# KakaoTalk message to me
KAKAO_REST_API_KEY=
KAKAO_REFRESH_TOKEN=
# KAKAO_CLIENT_SECRET=

# Optional: set this after GitHub Pages is ready.
# REPORT_PUBLIC_URL=https://your-name.github.io/your-repo/

# Optional: Supabase database persistence
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# If your Supabase dashboard shows a publishable key instead of anon key, use one of these names.
SUPABASE_PUBLISHABLE_KEY=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase Edge Function secret
# GITHUB_DISPATCH_TOKEN must be set in Supabase Function Secrets, not in browser code.
GITHUB_DISPATCH_TOKEN=

# External cron cloud sync
CRONJOB_API_KEY=

# Negative article watch defaults
NEGATIVE_WATCH_MINUTES=5
NEGATIVE_WATCH_ALWAYS_ON=true
NEGATIVE_WATCH_START_HOUR=0
NEGATIVE_WATCH_END_HOUR=23
