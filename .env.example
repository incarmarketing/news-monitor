# ============================================================
# 1) Monitoring profile
# ============================================================
# Use comma-separated values. Example:
# OWN_NAMES=샘플회사,샘플서비스
# MONITOR_KEYWORDS=샘플회사,샘플회사 브랜드평판,경쟁사명,정책 키워드

COMPANY_NAME=샘플회사
TEAM_NAME=모니터링팀
EMAIL_SUBJECT_PREFIX=[AI 모니터링]
OWN_NAMES=샘플회사
MONITOR_KEYWORDS=샘플회사,샘플회사 브랜드평판,경쟁사명,업계 키워드,정책 규제 키워드
EXCLUDE_KEYWORDS=채용,구인,알바,아르바이트,창업,무관 스포츠,무관 이벤트

HOURS_BACK=24
ARTICLES_PER_KEYWORD=25
TOP_N_FOR_BRIEFING=60
MAX_ARTICLES_FOR_PROMPT=32
SCHEDULE_TIMES=08:00,13:00,18:00

# ============================================================
# 2) Naver News API
# ============================================================
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ============================================================
# 3) Google Gemini API
# ============================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_EDGE_MODEL=gemini-2.5-pro
GEMINI_TIMEOUT_SECONDS=45
GEMINI_CIRCUIT_HOURS=6
GEMINI_CIRCUIT_CREDIT_HOURS=24

# Optional AI fallback for issue-only summaries
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_ISSUE_SUMMARIES=20

# ============================================================
# 4) KakaoTalk message to me
# ============================================================
KAKAO_REST_API_KEY=
KAKAO_REFRESH_TOKEN=
# KAKAO_CLIENT_SECRET=

# ============================================================
# 5) Public report URL
# ============================================================
# Set this after GitHub Pages is ready.
# REPORT_PUBLIC_URL=https://your-github-id.github.io/your-repo/
REPORT_PUBLIC_URL=
DASHBOARD_PUBLIC_URL=

# ============================================================
# 6) Supabase database persistence
# ============================================================
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Edge Function / GitHub dispatch
# GITHUB_DISPATCH_TOKEN must be set in Supabase Function Secrets too.
GITHUB_OWNER=your-github-id
GITHUB_REPO=your-repo
GITHUB_REF=main
GITHUB_DISPATCH_TOKEN=

# ============================================================
# 7) External cron cloud sync
# ============================================================
CRONJOB_API_KEY=
CRON_DISPATCH_TOKEN=
CRONJOB_TITLE_PREFIX=monitoring-template

# Negative article watch defaults
NEGATIVE_WATCH_MINUTES=5
NEGATIVE_WATCH_ALWAYS_ON=true
NEGATIVE_WATCH_START_HOUR=0
NEGATIVE_WATCH_END_HOUR=23

# Report scheduler safety
REPORT_FAILURE_COOLDOWN_MINUTES=30
REQUIRE_REPORT_LINK_OK=true
REQUIRE_DASHBOARD_QUALITY=false
